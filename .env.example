# =============================================================================
# Copy to .env.local (gitignored) and fill in real values. Never commit secrets.
# =============================================================================

# Supabase (Settings → API). New-format keys are drop-in compatible with the
# old var names below: put the "publishable" key in ANON, the "secret" key in
# SERVICE_ROLE. ANON/publishable is browser-safe (RLS-protected); SERVICE_ROLE/
# secret is server-only (bypasses RLS — used by the cron pipeline).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # anon OR sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=             # service_role OR sb_secret_... (server-side only)

# Google Sheets API — service account (Cloud Console → IAM & Admin → Service
# Accounts → Create → Keys → Add key → JSON). Paste the downloaded JSON's
# content here as ONE LINE (raw or base64 — a raw multi-line blob breaks
# standard .env parsing). The sheet itself must separately be shared with
# that key's client_email (Viewer is enough) — a service account has no
# access until you share a sheet with it, same as adding any other collaborator.
GOOGLE_SERVICE_ACCOUNT_KEY=
# Per-city spreadsheet id (the long id in the sheet's URL between /d/ and
# /edit). Each city's spreadsheet has separate "Outward" (direction=OUT) and
# "Inward" (direction=IN) tabs — override outwardSheet/inwardSheet per city if
# a tab is ever named differently. Column order is read from the header
# row's text, not fixed positions; the connector always pulls the last 200
# real data rows of each tab (see lib/connectors/sheets.ts).
# {"DELHI":{"spreadsheetId":"..."},"MUMBAI":{"spreadsheetId":"...","inwardSheet":"Inward "}, ...}
SHEETS_CONFIG=

# Odoo ERP — currently implemented via Metabase (see METABASE_* below), per
# DB MODEL.md §5/§6/§10. These are for the direct JSON-RPC/Postgres
# alternatives if you switch transport later (lib/connectors/odoo.ts).
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=
# For direct-Postgres transport instead, use a connection string:
# ODOO_PG_URL=postgresql://user:pass@host:5432/odoo

# Metabase (analytics.rentofurniture.com) — the Odoo connector's transport.
# Auth: either an API key, OR a username+password session (pick one).
METABASE_URL=https://analytics.rentofurniture.com
METABASE_API_KEY=
# METABASE_USERNAME=
# METABASE_PASSWORD=
# The numeric database id Metabase assigns to "Odoo Live Database" — look
# this up via GET /api/database once authenticated (DB MODEL.md doesn't give
# this one; it only confirms DT's Mongo connection is id 6).
METABASE_ODOO_DB_ID=

# Delivery Tracker (MongoDB). Store the full connection string here — NOT in code.
DT_MONGODB_URI=
DT_MONGODB_DB=cityfurnish
# Parent collection joined to orderfromcityfurnishes (barcode lines). DB MODEL.md
# named it "tasks", but that collection is empty on the live cluster — the real
# one is "deliveries" (the default). Override only if it's renamed again.
DT_TASKS_COLLECTION=deliveries
# (legacy HTTP-API vars, unused if reading Mongo directly)
DT_API_BASE_URL=
DT_API_KEY=

# Guard OCR — Azure AI Vision, Computer Vision v3.2 async "Read" API (the only
# variant that natively accepts multi-page PDF; the newer v4.0 Image Analysis
# API is images-only). Endpoint looks like https://<resource>.cognitiveservices.azure.com
AZURE_VISION_ENDPOINT=
AZURE_VISION_API_KEY=

# Email (Resend)
RESEND_API_KEY=
DIGEST_RECIPIENTS=

# Cron protection — random secret; must match the scheduler's Authorization header
CRON_SECRET=
